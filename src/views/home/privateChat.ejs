<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= pageTitle %>
    </title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://kit.fontawesome.com/678ee4d480.js" crossorigin="anonymous"></script>

</head>

<body>
    <div class="w-full h-screen grid grid-flow-cols grid-cols-[2fr_5fr]">

        <!-- Left Portion of the page -->
        <div class="overflow-hidden w-full h-full bg-yellow-200 border border-black flex flex-col items-center justify-start gap-1">
            <!-- Left upper part -->
            <div class="w-full h-30 bg-yellow-200 flex flex-col gap-2 items-center justify-start">
                <div class="w-full flex gap-2">
                    <div><i class="fa-brands fa-whatsapp fa-xl"></i></div>
                    <p>Welcome, <%=user.username%></p>
                </div>
                <form class="flex items-around justify-between" action="/finduser" method="post">
                    <input id="searchUser" class="relative w-90 mx-2 p-2 h-10 rounded-xl border-black border-2" type="text" placeholder="Enter" name="search">
                    <button class="absolute top-6 left-75 mt-3 h-7 w-15 rounded-xl" type="submit">Search</button>
                </form>
            </div>

            <!-- Left lower part -->
            <div class="overflow-scroll scrollbar-none">
                <% if(chat.length > 0) {%>
                    <% chat.forEach((elem)=> {%>
                        <a href="/chat/<%=elem.receiver.id%>">
                            <div class="border border-black rounded-xl m-2 p-1 flex items-center justify-start gap-1 w-87 h-15 active:bg-gray-600">
                                <img class="mx-1 w-8 h-8 object-cover rounded-full" src="<%= elem.receiver.imageUrl %>" alt="https://i.pinimg.com/236x/15/0f/a8/150fa8800b0a0d5633abc1d1c4db3d87.jpg?nii=t">
                                <div>
                                    <%= elem.receiver.username %>
                                </div>
                            </div>
                        </a>
                    <%}) %>
                <%} %>
            </div>
        </div>

        <!-- Right Portion of the page -->
        <div class="w-full h-full bg-white border border-black flex flex-col items-start justify-start">
            <!-- Top Right part -->
            <div class="w-full h-13 bg-black flex gap-2 items-center justify-center">
                <div class="w-full flex gap-1 items-center justify-start overflow-hidden">
                    <img class="mx-1 w-8 h-8 object-cover rounded-full" src="<%=receiver.imageUrl%>" alt="https://i.pinimg.com/236x/15/0f/a8/150fa8800b0a0d5633abc1d1c4db3d87.jpg?nii=t">
                    <p class="text-white"><%= receiver.username %></p>
                </div>
            </div>

            <!-- Top middle part -->
            <div id="messageContainer" class="p-1 w-full h-133 overflow-scroll scrollbar-none">
                <% if(messages.length > 0) {%>
                    <% messages.forEach((elem)=> {%>
                        <% if(elem.senderId === user.id) {%>
                            <div class="w-full h-13">
                                <div class="w-fit h-fit overflow-scroll scrollbar-none p-2 bg-blue-300 text-white">
                                    <%= elem.message %>
                                </div>  
                            </div>
                        <%}else { %>
                            <div class="w-full h-13 flex items-end justify-end">
                                <div class="w-fit h-fit overflow-scroll scrollbar-none p-2 bg-green-300 text-white">
                                    <%= elem.message %>
                                </div>  
                            </div>
                        <% } %>
                    <%}) %>
                <%}else { %>
                    <div class="w-full h-133 flex items-center justify-center">
                        <h2>Start A chat, No chat found</h2>
                    </div>
                <% } %>
            </div>

            <!-- Right bottom part -->
            <div class="w-full h-11 flex items-center justify-center">
                <form id="textForm" class="flex items-center justify-center w-full h-full" action="/chat/<%=receiver.id%>" method="post">
                    <input id="receiver" type="hidden" value="<%-receiver.id%>">
                    <input id="messageInput" class="mx-1 p-2 h-full w-full bg-white border border-black rounded-xl" type="text" name="message" placeholder="message">
                    <button id="sendBtn" class="mx-1 h-10 w-11 rounded-full bg-green-600" type="submit">
                        <i class="fa-solid fa-paper-plane"></i>
                    </button>
                </form>
            </div>
        </div>

    </div>

    <script src="/socket.io/socket.io.js"></script>

    <script src="/js/privateChat.js"></script>


</body>

</html>

